<Window x:Class="FlightDataRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Oceny Lądowania - A320neo" Height="320" Width="400">
    <StackPanel Margin="20">
        <TextBlock x:Name="StatusText" Text="Status: Odłączony" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" Foreground="Red"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Próg RA (ft AGL):" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtRaThresholdFt" Width="72" Text="3000" VerticalAlignment="Center"/>
        </StackPanel>
        <Button x:Name="BtnConnect" Content="Połącz z MSFS" Click="BtnConnect_Click" Height="35" Margin="0,5" Background="LightBlue"/>
        <Button x:Name="BtnStart" Content="Rozpocznij Nagrywanie" Click="BtnStart_Click" Height="35" Margin="0,5" IsEnabled="False" Background="LightGreen"/>
        <Button x:Name="BtnStop" Content="Zatrzymaj Nagrywanie" Click="BtnStop_Click" Height="35" Margin="0,5" IsEnabled="False" Background="LightCoral"/>
    </StackPanel>
</Window>